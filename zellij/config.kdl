keybinds {
    normal {
        unbind "Alt f"
        bind "Alt g" { ToggleFloatingPanes; }
    }
    shared_except "locked" {
        unbind "Ctrl g"
        bind "Ctrl /" { SwitchToMode "Locked"; }
        bind "Alt h" "Alt Left"  { MoveFocus "Left"; }
        bind "Alt l" "Alt Right" { MoveFocus "Right"; }
        bind "Alt x" { SwitchToMode "Normal"; CloseFocus; }
    }
    locked {
        unbind "Ctrl g"
        bind "Ctrl /" { SwitchToMode "Normal"; }
    }
}

plugins {
    zjstatus location="file:~/.config/zellij/plugins/zjstatus.wasm" {
        border_enabled "false"
    }
}

themes {
    obsidian {
        fg "#c5c9c5"
        bg "#14181c"
        black "#0d0c0c"
        red "#c4746e"
        green "#8a9a7b"
        yellow "#c4b28a"
        blue "#8ba4b0"
        magenta "#a292a3"
        cyan "#8ea4a2"
        white "#a6a69c"
        orange "#ffa066"
        frame_selected {
            base 100 112 132
            background 38 42 52
            emphasis_0 130 142 160
            emphasis_1 130 142 160
            emphasis_2 130 142 160
            emphasis_3 130 142 160
        }
        frame_unselected {
            base 50 56 70
            background 28 30 38
            emphasis_0 70 78 96
            emphasis_1 70 78 96
            emphasis_2 70 78 96
            emphasis_3 70 78 96
        }
        frame_highlight {
            base 100 112 132
            background 38 42 52
            emphasis_0 130 142 160
            emphasis_1 130 142 160
            emphasis_2 130 142 160
            emphasis_3 130 142 160
        }
    }
}

theme "obsidian"

// Allow applications to bypass Zellij's terminal emulation
// Fixes garbled escape sequences in Claude Code and other TUI apps
support_kitty_keyboard_protocol true
show_startup_tips false
