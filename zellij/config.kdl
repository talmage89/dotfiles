keybinds {
    normal {
        bind "Alt x" { CloseFocus; }
        unbind "Alt f"
        bind "Alt g" { ToggleFloatingPanes; }
    }
}

themes {
    kanagawa-dragon {
        fg "#c5c9c5"
        bg "#181616"
        black "#0d0c0c"
        red "#c4746e"
        green "#8a9a7b"
        yellow "#c4b28a"
        blue "#8ba4b0"
        magenta "#a292a3"
        cyan "#8ea4a2"
        white "#a6a69c"
        orange "#ffa066"
    }
}

theme "kanagawa-dragon"

// Allow applications to bypass Zellij's terminal emulation
// Fixes garbled escape sequences in Claude Code and other TUI apps
support_kitty_keyboard_protocol true
